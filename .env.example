# ============================================================================
# APP
# Configuracion general de la aplicacion Laravel
# ============================================================================
APP_NAME="Atlantia Supermarket"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=America/Guatemala
APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_GT
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Numero de rondas bcrypt para contrasenas
BCRYPT_ROUNDS=12

# ============================================================================
# LOGGING
# Canales y nivel de logs
# ============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

# ============================================================================
# DATABASE
# Conexion a base de datos MySQL
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=atlantia_supermarket
DB_USERNAME=atlantia_app
# Llenar con la contrasena local o del servidor
ATLANTIA_DB_PASSWORD=your-db-password-here

# ============================================================================
# SESSION
# Sesiones de usuario cifradas
# ============================================================================
SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ============================================================================
# CACHE
# Cache principal de la aplicacion
# ============================================================================
CACHE_STORE=redis
CACHE_PREFIX=

# ============================================================================
# QUEUE
# Cola principal para jobs asincronos
# ============================================================================
QUEUE_CONNECTION=redis

# ============================================================================
# BROADCAST Y FILESYSTEM
# Configuraciones base del framework
# ============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ============================================================================
# REDIS
# Sesiones, cache y colas
# ============================================================================
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=queue
MEMCACHED_HOST=127.0.0.1

# ============================================================================
# MAIL
# Servidor SMTP para correos transaccionales
# ============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
# Llenar con la contrasena de aplicacion del buzón SMTP
ATLANTIA_MAIL_APP_PASSWORD=your-mail-app-password-here
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@atlantiasupermarket.com
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================================
# STORAGE S3 COMPATIBLE
# Archivos y multimedia
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================================
# SERVICES - MAPBOX
# Token publico para mapas y geocodificacion web
# ============================================================================
ATLANTIA_MAPBOX_TOKEN=your-mapbox-public-token-here
MAPBOX_BASE_URL=https://api.mapbox.com

# ============================================================================
# SERVICES - MEILISEARCH
# Motor de busqueda del catalogo
# ============================================================================
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=your-meilisearch-master-key-here
SCOUT_DRIVER=meilisearch

# ============================================================================
# SERVICES - FEL INFILE
# Certificacion electronica de facturas Guatemala
# ============================================================================
INFILE_BASE_URL=https://sandbox.infile.com
INFILE_USERNAME=your-infile-user-here
INFILE_PASSWORD=your-infile-password-here
INFILE_WEBHOOK_SECRET=your-infile-webhook-secret-here

# ============================================================================
# PAYMENT - PASARELA GENERICA
# Contrato compatible para pasarela intercambiable
# ============================================================================
PAYMENT_GATEWAY_BASE_URL=https://payments.example.test
PAYMENT_GATEWAY_MERCHANT_ID=your-merchant-id-here
PAYMENT_GATEWAY_SECRET=your-payment-secret-here
PAYMENT_GATEWAY_WEBHOOK_SECRET=your-payment-webhook-secret-here

# ============================================================================
# PAYMENT - STRIPE
# Claves reales de cobro con tarjeta
# ============================================================================
STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_key
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_secret
STRIPE_CURRENCY=gtq

# ============================================================================
# ML
# Microservicio de modelos y prediccion
# ============================================================================
ML_SERVICE_URL=http://127.0.0.1:8001
ML_SERVICE_TOKEN=your-ml-service-token-here
ML_WEBHOOK_SECRET=your-ml-webhook-secret-here
ML_TIMEOUT_SECONDS=10

# ============================================================================
# WEBHOOKS ADICIONALES
# Integraciones externas
# ============================================================================
COURIER_WEBHOOK_SECRET=your-courier-webhook-secret-here

# ============================================================================
# SECURITY - RECAPTCHA
# Proteccion contra fraude y bots
# ============================================================================
RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
RECAPTCHA_MINIMUM_SCORE=0.6

# ============================================================================
# SUPER ADMIN
# Cuenta de arranque para gobierno total de plataforma
# ============================================================================
ATLANTIA_SUPER_ADMIN_ENABLED=true
ATLANTIA_SUPER_ADMIN_NAME="Super Administrador Atlantia"
ATLANTIA_SUPER_ADMIN_EMAIL=superadmin@example.com
ATLANTIA_SUPER_ADMIN_PASSWORD=change-this-super-admin-password
ATLANTIA_SUPER_ADMIN_PHONE=50200000000

# ============================================================================
# FRONTEND
# Variables expuestas a Vite
# ============================================================================
VITE_APP_NAME="${APP_NAME}"
