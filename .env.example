APP_NAME="Atlantia Supermarket"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=America/Guatemala

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_GT

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=atlantia_supermarket
DB_USERNAME=atlantia_app
ATLANTIA_DB_PASSWORD=your-db-password-here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
ATLANTIA_MAIL_APP_PASSWORD=your-mail-app-password-here
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@atlantiasupermarket.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

ATLANTIA_MAPBOX_TOKEN=your-mapbox-public-token-here
MAPBOX_BASE_URL=https://api.mapbox.com

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=your-meilisearch-master-key-here
SCOUT_DRIVER=meilisearch

INFILE_BASE_URL=https://sandbox.infile.com
INFILE_USERNAME=your-infile-user-here
INFILE_PASSWORD=your-infile-password-here
INFILE_WEBHOOK_SECRET=your-infile-webhook-secret-here

PAYMENT_GATEWAY_BASE_URL=https://payments.example.test
PAYMENT_GATEWAY_MERCHANT_ID=your-merchant-id-here
PAYMENT_GATEWAY_SECRET=your-payment-secret-here
PAYMENT_GATEWAY_WEBHOOK_SECRET=your-payment-webhook-secret-here

ML_SERVICE_URL=http://127.0.0.1:8001
ML_SERVICE_TOKEN=your-ml-service-token-here
ML_WEBHOOK_SECRET=your-ml-webhook-secret-here
ML_TIMEOUT_SECONDS=10

COURIER_WEBHOOK_SECRET=your-courier-webhook-secret-here

RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here
RECAPTCHA_MINIMUM_SCORE=0.6

ATLANTIA_SUPER_ADMIN_ENABLED=true
ATLANTIA_SUPER_ADMIN_NAME="Super Administrador Atlantia"
ATLANTIA_SUPER_ADMIN_EMAIL=superadmin@example.com
ATLANTIA_SUPER_ADMIN_PASSWORD=change-this-super-admin-password
ATLANTIA_SUPER_ADMIN_PHONE=50200000000

VITE_APP_NAME="${APP_NAME}"
