APP_NAME="Atlantia Supermarket"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=atlantia
DB_USERNAME=atlantia
ATLANTIA_DB_PASSWORD=your-local-db-password-here

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_ENCRYPT=true

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=your-local-meilisearch-key-here

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=your-local-minio-password-here
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=atlantia
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

ML_SERVICE_URL=http://ml-api:8000
ML_SERVICE_TOKEN=your-local-ml-service-token-here
ML_WEBHOOK_SECRET=your-local-ml-webhook-secret-here

ATLANTIA_MAPBOX_TOKEN=
INFILE_BASE_URL=https://sandbox.infile.com.gt/api
INFILE_MOCK=true
PAYMENT_GATEWAY_WEBHOOK_SECRET=your-local-payment-webhook-secret-here

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=gtq
